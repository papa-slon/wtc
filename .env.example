# WTC Ecosystem Platform — environment template.
# Copy to .env and fill REAL values locally. NEVER commit .env. NEVER copy server secrets here.

NODE_ENV=development

# Deployment-environment axis (distinct from NODE_ENV). development | test | staging | production.
# A real deploy MUST set this: staging|production REQUIRE the Axioma ES256 signing key below (the HS256
# dev stub is fenced out of staging/production). Leave 'development' for local dev.
APP_ENV=development

# --- Database (local docker-compose Postgres) ---
DATABASE_URL=postgres://wtc:wtc@localhost:5432/wtc

# --- Real-Postgres acceptance harness (opt-in; NEVER point at a live or populated DB) ---
# DB name MUST be wtc_test or start with wtc_test_. See docs/DEPLOYMENT.md for the full
# throwaway-DB flow. Leave this variable UNSET to skip the harness (npm test stays green).
# REAL_POSTGRES_DATABASE_URL=postgres://<user>:<password>@127.0.0.1:5432/wtc_test

# --- Audit append-only role acceptance (opt-in; writes one safe system.health_check audit row) ---
# Use the restricted application DB role, not an admin or migration role.
# By default the DB name MUST be wtc_test or start with wtc_test_. For an approved preview/prod target,
# set AUDIT_APPEND_ONLY_PREFLIGHT_NON_THROWAWAY_APPROVED=1 only for that run.
# AUDIT_APPEND_ONLY_DATABASE_URL=postgres://wtc_app_role:<password>@127.0.0.1:5432/wtc_test_audit_role
# AUDIT_APPEND_ONLY_EXPECTED_ROLE=wtc_app_role
# AUDIT_APPEND_ONLY_PREFLIGHT_ACCEPT=1
# AUDIT_APPEND_ONLY_PREFLIGHT_NON_THROWAWAY_APPROVED=1

# --- LMS DB browser acceptance harness (opt-in; NEVER point at preview/prod) ---
# Manual path: set LMS_E2E_DATABASE_URL to an already-created fresh empty wtc_test_lms_* database.
# Managed path: set LMS_E2E_ADMIN_DATABASE_URL to a non-throwaway maintenance DB; the runner creates
# and drops a fresh wtc_test_lms_* database itself. See docs/DEPLOYMENT.md.
# LMS_E2E_DATABASE_URL=postgres://<user>:<password>@127.0.0.1:5432/wtc_test_lms_yyyymmddhhmmss
# LMS_E2E_ADMIN_DATABASE_URL=postgres://<user>:<password>@127.0.0.1:5432/postgres

# --- LMS file storage ---
# db-local keeps file bytes in the material row for local/dev acceptance.
# fs-local writes bytes under LMS_FILE_STORAGE_ROOT and stores provider/key metadata in Postgres.
# s3-r2 writes to an S3/R2-compatible private bucket and returns short-lived signed redirects.
# Public production uploads MUST stay disabled until live object-store + external scanner acceptance is observed.
LMS_FILE_STORAGE_PROVIDER=db-local     # db-local | fs-local | s3-r2
# LMS_FILE_STORAGE_ROOT=C:\wtc-lms-files
# LMS_OBJECT_STORAGE_ENDPOINT=https://<account-or-region-object-endpoint>
# LMS_OBJECT_STORAGE_BUCKET=<private-bucket-name>
# LMS_OBJECT_STORAGE_REGION=auto
# LMS_OBJECT_STORAGE_ACCESS_KEY_ID=<object-store-access-key-id>
# LMS_OBJECT_STORAGE_SECRET_ACCESS_KEY=<object-store-secret-access-key>
# All *_PREFLIGHT_LOG_ROOT overrides must be relative repo-local logs/... paths.
# Absolute, UNC, URL-shaped, parent-traversal, non-logs roots, symlinks, junctions,
# and other reparse-point path components are refused.
# Live object-store preflight only; never needed for normal app boot.
# LMS_OBJECT_STORAGE_LIVE_ACCEPTANCE=1
# LMS_OBJECT_STORAGE_LIVE_THROWAWAY=1
# LMS_OBJECT_STORAGE_PREFLIGHT_LOG_ROOT=logs/lms-s3-r2-preflight
LMS_FILE_SCANNER_MODE=local-signature  # local-signature | external
# Required when LMS_FILE_SCANNER_MODE=external. The scanner endpoint receives raw bytes server-side.
# LMS_FILE_SCANNER_ENDPOINT=https://<scanner-service>/scan
# LMS_FILE_SCANNER_TOKEN=<scanner-service-token>
# LMS_FILE_SCANNER_TIMEOUT_MS=5000
# Live scanner preflight only; never needed for normal app boot.
# LMS_FILE_SCANNER_LIVE_ACCEPTANCE=1
# LMS_FILE_SCANNER_LIVE_EICAR=1
# LMS_FILE_SCANNER_PREFLIGHT_LOG_ROOT=logs/lms-external-scanner-preflight
LMS_PUBLIC_UPLOADS_ENABLED=false

# --- Sessions / CSRF ---
# 32+ random bytes, base64. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=replace-with-random-48-bytes-base64

# --- Secret vault (exchange API key encryption) ---
# KEK = 32 random bytes, base64. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRET_VAULT_KEK=replace-with-random-32-bytes-base64
SECRET_VAULT_KEY_ID=kek-2026-05

# --- Feature flags (safe defaults: OFF) ---
FEATURE_LIVE_BOT_CONTROL=false      # live bot start/stop/apply — stays off until audited
FEATURE_TV_AUTOMATION=false         # TradingView automation — manual queue is the default

# --- Bot adapter mode (single source of truth) ---
# mock (default) => synthetic mock adapters, no network
# read-only      => real HTTP GET-only adapters (phase gate; data methods still stubbed)
# audited        => read-only + future audited control path (control still disabled in code)
BOT_ADAPTER_MODE=mock

# --- Bot endpoints (only used when BOT_ADAPTER_MODE != mock) ---
# TORTILA_JOURNAL_URL is the canonical var for the Tortila journal base URL.
# Both TORTILA_JOURNAL_URL and TORTILA_JOURNAL_BASE_URL are supported for backwards compatibility.
TORTILA_JOURNAL_URL=http://127.0.0.1:8080
TORTILA_JOURNAL_BASE_URL=http://127.0.0.1:8080
LEGACY_BOT_BASE_URL=http://127.0.0.1:8000
# Bearer token for the auth-gated Tortila journal. REQUIRED for BOT_ADAPTER_MODE != mock in production
# (the adapter reports readState 'not_configured' until it is set). Never commit a real token here.
JOURNAL_READ_TOKEN=
# Optional worker snapshot binding. Leave unset until Postgres is seeded and you know the UUIDs.
# SYSTEM_BOT_OWNER_ID=<wtc-user-uuid>
# SYSTEM_BOT_INSTANCE_ID=<bot-instance-uuid>

# --- Axioma bridge (read-only metadata; no exchange keys ever) ---
AXIOMA_JOURNAL_BASE_URL=https://axi-o.ma
AXIOMA_BRIDGE_API_TOKEN=             # service token for journal_server bridge, if issued
AXIOMA_ROUTE_SKELETON_ENABLED=false  # fail-closed Axioma API route skeletons; requires DB + bridge token + ES256 key
AXIOMA_HANDOFF_SIGNING_SECRET=replace-with-random-48-bytes-base64   # HS256 dev stub only (dev/test)
AXIOMA_HANDOFF_AUDIENCE=axi-o.ma
# ES256 (production-grade) handoff signer — REQUIRED when APP_ENV=staging|production. The PEM private
# key NEVER leaves the server and is NEVER emitted in JWKS (only the public JWK is served). Generate:
#   openssl ecparam -name prime256v1 -genkey -noout -out wtc-axioma.pem
# Provide the PEM (the EC PRIVATE KEY block) as a single \n-escaped line, or via your secret manager.
# B4: not provisioned in this environment, so staging/prod activation stays NOT RUN/TARGET.
# AXIOMA_HANDOFF_SIGNING_KEY=<ec-p256-pem-one-line>
# AXIOMA_HANDOFF_KEY_ID=wtc-axioma-sign-2026-01
# Local Axioma handoff preflight only; dry-run generates ephemeral P-256 material and performs no Axioma network I/O.
# AXIOMA_HANDOFF_PREFLIGHT_LOG_ROOT=logs/axioma-handoff-preflight

# --- Billing provider (mock by default) ---
BILLING_PROVIDER=mock                # mock | stripe | crypto
# STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET are optional placeholders.
# STRIPE_WEBHOOK_SECRET is REQUIRED for the webhook route to process any Stripe event.
# STRIPE_SECRET_KEY is REQUIRED for test-mode checkout session creation.
# Never set real (live) key values here. Generate test keys from Stripe Dashboard.
# The webhook route at POST /api/billing/webhook returns 400 until STRIPE_WEBHOOK_SECRET is set.
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_stripe_webhook_secret
STRIPE_PRICE_MAP={"tortila_monthly":"price_replace_tortila_monthly","bundle_starter":"price_replace_bundle_starter"}
# Local Stripe webhook replay preflight only; dry-run uses generated fake fixtures and no Stripe network I/O.
# STRIPE_WEBHOOK_REPLAY_PREFLIGHT_LOG_ROOT=logs/billing-stripe-webhook-preflight
# Local Stripe checkout request preflight only; dry-run uses generated fake fixtures and no Stripe network I/O.
# STRIPE_CHECKOUT_PREFLIGHT_LOG_ROOT=logs/billing-stripe-checkout-preflight

# --- App ---
APP_BASE_URL=http://localhost:3000
PORT=3000
