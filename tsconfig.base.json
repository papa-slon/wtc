{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@wtc/shared": ["packages/shared/src/index.ts"],
      "@wtc/shared/*": ["packages/shared/src/*"],
      "@wtc/config": ["packages/config/src/index.ts"],
      "@wtc/crypto": ["packages/crypto/src/index.ts"],
      "@wtc/db": ["packages/db/src/index.ts"],
      "@wtc/auth": ["packages/auth/src/index.ts"],
      "@wtc/auth/rate-limit": ["packages/auth/src/rate-limit.ts"],
      "@wtc/auth/security-headers": ["packages/auth/src/security-headers.ts"],
      "@wtc/audit": ["packages/audit/src/index.ts"],
      "@wtc/entitlements": ["packages/entitlements/src/index.ts"],
      "@wtc/billing": ["packages/billing/src/index.ts"],
      "@wtc/analytics": ["packages/analytics/src/index.ts"],
      "@wtc/bot-adapters": ["packages/bot-adapters/src/index.ts"],
      "@wtc/axioma-bridge": ["packages/axioma-bridge/src/index.ts"],
      "@wtc/lms": ["packages/lms/src/index.ts"],
      "@wtc/tradingview-access": ["packages/tradingview-access/src/index.ts"],
      "@wtc/backtester": ["packages/backtester/src/index.ts"],
      "@wtc/ui": ["packages/ui/src/index.ts"],
      "@wtc/cabinet": ["packages/cabinet/src/index.ts"]
    }
  }
}
