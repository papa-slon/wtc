{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": [
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "allowJs": true,
    "incremental": true
  },
  "include": [
    ".next-browser-verify/types/**/*.ts",
    ".next-e2e-auth-db/types/**/*.ts",
    ".next-e2e-auth-db/types/**/*.ts",
    ".next-e2e-auth/types/**/*.ts",
    ".next-e2e-db/types/**/*.ts",
    ".next-e2e/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next-e2e-admin-user-bots/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
